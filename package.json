{
  "name": "@diegovelasquezweb/a11y-engine",
  "version": "0.4.1",
  "description": "WCAG 2.2 AA accessibility audit engine — scanner, analyzer, and report builders",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/diegovelasquezweb/a11y-engine.git"
  },
  "homepage": "https://github.com/diegovelasquezweb/a11y-engine#readme",
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./src/index.d.mts",
      "default": "./src/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "main": "src/index.mjs",
  "types": "src/index.d.mts",
  "bin": {
    "a11y-audit": "src/cli/audit.mjs"
  },
  "files": [
    "src/**",
    "assets/source/**",
    "assets/generated/**",
    "docs/**",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "sync-assets": "node src/sync-assets.mjs",
    "test": "vitest run",
    "prepublishOnly": "node src/sync-assets.mjs"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.11.1",
    "axe-core": "^4.11.1",
    "pa11y": "^9.1.1",
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.22.0+sha512.bf049efe995b28f527fd2b41ae0474ce29186f7edcb3bf545087bd61fbbebb2bf75362d1307fda09c2d288e1e499787ac12d4fcb617a974718a6051f2eee741c"
}
